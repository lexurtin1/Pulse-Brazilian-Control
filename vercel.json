{
  "installCommand": "npm install && npm run build:packages",
  "buildCommand": "npm run migrate --workspace=@pulse-brazil/infrastructure && npm run build --workspace=@pulse-brazil/ui",
  "outputDirectory": "packages/ui/dist",
