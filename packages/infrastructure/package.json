{
  "name": "@pulse-brazil/infrastructure",
  "version": "0.1.0",
  "private": true,
  "description": "Infrastructure layer for Pulse Brazil: Postgres repositories, the Claude and geocoder adapters, and the composition root. Implements the ports declared in @pulse-brazil/application.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "migrate": "tsx src/db/run-migrations.ts",
    "seed": "tsx src/db/seed.ts",
    "reconcile:accounts": "tsx src/db/reconcile-salesforce-accounts.ts",
    "import:pipeline": "tsx src/db/import-pipeline-csv.ts",
    "recapture:account-count": "tsx src/db/recapture-account-count-snapshot.ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@neondatabase/serverless": "^1.1.0",
    "@pulse-brazil/application": "*",
    "@pulse-brazil/domain": "*",
    "pg": "^8.13.0",
    "ulid": "^2.3.0",
    "ws": "^8.18.0"
  }
}
